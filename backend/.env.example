# Flipkart Delivery Tracker — Python backend configuration.
# Copy to `backend/.env` (auto-loaded on local `uvicorn` runs; gitignored).
# In Docker these come from docker-compose instead. All optional — defaults are baked in.

# Timezone used by the frontend for the "today / next 7 days" filters.
APP_TIMEZONE=Asia/Kolkata

# Where dropped account cookies are persisted (Docker overrides this to /data/... on a volume).
SESSION_STORE_PATH=.flipkart-session.json

# Set to require the header "x-admin-token" on account add/remove. Blank = open (local use).
ADMIN_TOKEN=

# Paginate My Orders (7/page). Stops early when there are no more orders; safety cap (~700 orders).
FLIPKART_MAX_PAGES=100

# Fetch each order's detail page (delivery address + live OTP) for this many recent orders. 0 disables.
FLIPKART_MAX_DETAILS=40

# Per-request timeout in milliseconds.
FLIPKART_TIMEOUT_MS=20000

# curl_cffi TLS-impersonation profile used by Scrapling (chrome | chrome124 | edge | safari ...).
FLIPKART_IMPERSONATE=chrome

# ── Advanced (rarely changed) ────────────────────────────────────────────────
# Flipkart's custom x-user-agent (FKUA) header + a matching browser User-Agent.
#FLIPKART_FKUA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36 FKUA/website/42/website/Desktop
#FLIPKART_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36
# Internal API endpoints + the list filter (change only if Flipkart moves them).
#FLIPKART_ORDERS_BASE=https://www.flipkart.com/api/5/self-serve/orders/
#FLIPKART_DETAIL_URL=https://www.flipkart.com/api/4/page/fetch?
#FLIPKART_FILTER_TYPE=PREORDER_UNITS
