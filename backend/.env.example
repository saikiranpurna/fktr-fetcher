# Flipkart Delivery Tracker — Python backend configuration.
# All optional; sensible defaults are baked in.

# Timezone used by the frontend for the "today/next 7 days" filters.
APP_TIMEZONE=Asia/Kolkata

# Where dropped account cookies are persisted. In Docker this is a mounted volume.
SESSION_STORE_PATH=/data/flipkart-session.json

# Set to require the header "x-admin-token" on account add/remove. Blank = open (local use).
ADMIN_TOKEN=

# Paginate My Orders (7/page, most recent first) up to this many pages.
FLIPKART_MAX_PAGES=20

# Fetch each order's detail page (delivery address + live OTP) for this many recent orders. 0 disables.
FLIPKART_MAX_DETAILS=40

# Per-request timeout in milliseconds.
FLIPKART_TIMEOUT_MS=20000

# curl_cffi TLS-impersonation profile used by Scrapling (chrome | chrome124 | edge | safari ...).
FLIPKART_IMPERSONATE=chrome
