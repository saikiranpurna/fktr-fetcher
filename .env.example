# ─────────────────────────────────────────────────────────────────────────────
# Flipkart Delivery Tracker — configuration
#
# Copy this file to `.env.local`. In the default (browser) mode you don't NEED to
# set anything here — just run the app and add each Flipkart account's cookie in the
# Accounts panel (Manage → paste the Cookie-Editor JSON). Everything below has a
# sensible default; change it only if you need to.
# ─────────────────────────────────────────────────────────────────────────────

# ── FETCH MODE ───────────────────────────────────────────────────────────────
# browser (default): opens flipkart.com "My Orders" in headless Chromium using your
#   cookie and reads the orders off the page. Needs only the account cookie.
# http: advanced — replays a known orders JSON endpoint directly (set FLIPKART_ORDERS_URL).
FLIPKART_FETCH_MODE=browser

# browser mode: the My Orders page URL. Leave blank to use the default
#   (https://www.flipkart.com/account/orders).
# http mode: the orders JSON endpoint you captured (DevTools → Network → Copy as cURL).
FLIPKART_ORDERS_URL=

# Accounts are added in the app (drop each account's cookie .json in the Accounts
# panel) — there are no default/fallback accounts configured here.

# ── OPTIONAL — safe defaults shown; change only if you need to ────────────────

# Timezone used to decide what counts as "today".
APP_TIMEZONE=Asia/Kolkata

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# Extra request headers as a JSON object (e.g. User-Agent, CSRF). Default: none.
FLIPKART_BASE_HEADERS={}

# Give up on a slow account after this many milliseconds (also the page-render budget).
FLIPKART_TIMEOUT_MS=15000

# Browser mode paginates My Orders (7 orders/page, most recent first) up to this many
# pages. Raise it to pull more history; lower it for faster refreshes.
FLIPKART_MAX_PAGES=20

# Also fetch each order's detail page for the delivery address (+ live OTP), for at most this
# many most-recent orders. 0 disables it (faster). Higher = more addresses but slower refresh.
FLIPKART_MAX_DETAILS=40

# File where uploaded account cookies are saved on the server (gitignored).
SESSION_STORE_PATH=.flipkart-session.json

# Set a secret here to require the header "x-admin-token" before anyone can
# add/remove accounts. Leave blank to allow anyone (fine for local use).
ADMIN_TOKEN=

# Residential proxy — only needed if scraping many accounts from one server IP
# gets rate-limited/blocked. Leave blank for a direct connection.
# Include the literal {session} token to give each account its own sticky IP.
# Example (Decodo): http://USER-session-{session}:PASS@gate.decodo.com:7000
FLIPKART_PROXY_URL=
