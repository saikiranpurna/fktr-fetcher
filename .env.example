# =============================================================================
# docker compose — copy to `.env` (gitignored) to tune the BACKEND without
# editing docker-compose.yml. All optional; compose already defaults each.
# =============================================================================
APP_TIMEZONE=Asia/Kolkata
ADMIN_TOKEN=
FLIPKART_MAX_PAGES=100
FLIPKART_MAX_DETAILS=40
FLIPKART_TIMEOUT_MS=20000

# =============================================================================
# local `npm run dev` (frontend only; docker compose bakes these itself)
#   NEXT_PUBLIC_BACKEND_URL — URL the browser calls directly; empty = same-origin (Next proxy)
#   BACKEND_URL             — server-side rewrite-proxy target for dev
# =============================================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
